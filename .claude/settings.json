{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git remote -v*)",
      "Bash(git fetch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git stash list*)",
      "Bash(git stash show*)",
      "Bash(git worktree*)",
      "Bash(git blame*)",
      "Bash(git ls-files*)",
      "Bash(git switch -)",
      "Bash(git switch main)",
      "Bash(git switch feature/*)",
      "Bash(git switch fix/*)",
      "Bash(git switch -c feature/*)",
      "Bash(git switch -c fix/*)",
      "Bash(xcodebuild test*)",
      "Bash(xcodebuild build*)",
      "Bash(xcodebuild clean*)",
      "Bash(xcodebuild -list*)",
      "Bash(xcodebuild -showBuildSettings*)",
      "Bash(xcrun simctl list*)",
      "Bash(swift build*)",
      "Bash(swift test*)",
      "Bash(swift package*)",
      "Bash(swiftlint*)",
      "Bash(swift-format*)",
      "Bash(source \"$(git rev-parse --show-toplevel)/scripts/sim-dest.sh\")",
      "Bash(source \"$(git rev-parse --show-toplevel)/scripts/sim-dest.sh\" && xcodebuild test*)",
      "Bash(source \"$(git rev-parse --show-toplevel)/scripts/sim-dest.sh\" && xcodebuild build*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(gh run watch*)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(wc *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && swiftlint lint --quiet --strict"
          },
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && xcodebuild build -scheme Pastura -project Pastura/Pastura.xcodeproj -destination 'generic/platform=iOS Simulator' -quiet 2>&1 || (echo 'Build failed. Fix compile errors before committing.' >&2 && exit 2)"
          },
          {
            "type": "command",
            "command": "bash $(git rev-parse --show-toplevel)/scripts/blocklist-precommit-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash(gh pr create*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd $(git rev-parse --show-toplevel) && git diff main...HEAD --name-only | grep -q CLAUDE.md || echo '{\"hookSpecificOutput\":{\"warning\":\"CLAUDE.md not modified in this branch. Check if implementation progress needs updating.\"}}'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"additionalContext\":\"Reminder: This is Pastura (Swift/iOS). Follow CLAUDE.md hard rules. No force unwrap (!), no Engine→Data imports, TDD mandatory for Engine/LLM layers.\"}}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"additionalContext\":\"Before exiting: (1) Check if any memory files need to be created or updated based on this session. (2) Share any concerns, observations, or suggestions you noticed during this session but did not have a chance to mention.\"}}'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".swift\"))' | xargs -I {} sh -c 'swift-format format --in-place \"$1\" && swiftlint lint --fix --quiet \"$1\"' _ {}"
          }
        ]
      }
    ]
  }
}
